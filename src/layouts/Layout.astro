---
import '../styles/global.css';
const { title } = Astro.props;
---

<html lang="en" class="scroll-smooth scroll-pt-28">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    
    <title>Baby Bella Italian Foods | {title}</title>
    
    <link rel="icon" type="image/jpeg" href="/BellaItalianFoods/images/logo.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  </head>
  <body class="bg-background text-gray-800 font-cute antialiased min-h-screen flex flex-col">
    
    <header class="bg-white py-4 shadow-sm sticky top-0 z-50 relative">
      <div class="max-w-6xl mx-auto px-6 flex justify-between items-center">
        
        <a href="/BellaItalianFoods/" class="flex items-center">
          <img src="/BellaItalianFoods/images/logo.jpg" alt="Baby Bella Italian Foods Logo" class="h-12 w-auto" />        
        </a>
        
        <button id="mobile-menu-btn" class="md:hidden text-2xl focus:outline-none hover:text-primary transition-colors" aria-label="Toggle Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
        
        <nav id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-white shadow-md flex-col items-center space-y-6 py-6 md:static md:flex md:flex-row md:space-y-0 md:space-x-8 md:w-auto md:bg-transparent md:shadow-none md:py-0 font-semibold text-secondary">
          <a href="/BellaItalianFoods/#home" class="hover:text-primary transition-colors">Home</a>
          <a href="/BellaItalianFoods/#about" class="hover:text-primary transition-colors">About</a>
          <a href="/BellaItalianFoods/shop" class="hover:text-primary transition-colors">Shop</a>
          <a href="/BellaItalianFoods/contact" class="hover:text-primary transition-colors">Contact</a>
        </nav>
      </div>
    </header>

    <main class="flex-grow w-full">
      <slot /> 
    </main>

    <!-- BRANDS WE TRUST SECTION -->
    <section class="bg-brands-bg text-gray-800 pt-10 pb-16 mt-12 rounded-t-3xl">
      <div class="max-w-6xl mx-auto px-6">
        
        <div class="text-center mb-8">
          <h3 class="text-2xl font-bold tracking-tight text-secondary">Brands We Trust</h3>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 md:gap-6 items-center justify-center">
          <div class="flex items-center justify-center h-12 md:h-14 transition-all duration-300 hover:scale-110 cursor-pointer group">
            <img src="/BellaItalianFoods/images/brands/mustela.png" alt="Mustela Logo" class="h-full w-auto object-contain opacity-90 group-hover:opacity-100 transition-opacity mix-blend-multiply" />
          </div>
          <div class="flex items-center justify-center h-12 md:h-14 transition-all duration-300 hover:scale-110 cursor-pointer group">
            <img src="/BellaItalianFoods/images/brands/crescendo.png" alt="Crescendo Logo" class="h-full w-auto object-contain opacity-90 group-hover:opacity-100 transition-opacity mix-blend-multiply" />
          </div>
          <div class="flex items-center justify-center h-12 md:h-14 transition-all duration-300 hover:scale-110 cursor-pointer group">
            <img src="/BellaItalianFoods/images/brands/humana.png" alt="Humana Logo" class="h-full w-auto object-contain opacity-90 group-hover:opacity-100 transition-opacity mix-blend-multiply" />
          </div>
          <div class="flex items-center justify-center h-12 md:h-14 transition-all duration-300 hover:scale-110 cursor-pointer group">
            <img src="/BellaItalianFoods/images/brands/hipp.png" alt="HiPP Logo" class="h-full w-auto object-contain opacity-90 group-hover:opacity-100 transition-opacity mix-blend-multiply" />
          </div>
          <div class="flex items-center justify-center h-12 md:h-14 transition-all duration-300 hover:scale-110 cursor-pointer group">
            <img src="/BellaItalianFoods/images/brands/plasmon.png" alt="Plasmon Logo" class="h-full w-auto object-contain opacity-90 group-hover:opacity-100 transition-opacity mix-blend-multiply" />
          </div>
          <div class="flex items-center justify-center h-12 md:h-14 transition-all duration-300 hover:scale-110 cursor-pointer group">
            <img src="/BellaItalianFoods/images/brands/melling.png" alt="Mellin Logo" class="h-full w-auto object-contain opacity-90 group-hover:opacity-100 transition-opacity mix-blend-multiply" />
          </div>
        </div>

      </div>
    </section>

    <!-- MAIN FOOTER (Smaller & Compact) -->
    <footer class="bg-primary text-white pb-8 relative mt-0 pt-4">
      
      <!-- TOP SVG WAVE DIVIDER -->
      <div class="absolute bottom-full left-0 w-full overflow-hidden leading-[0] -mb-px">
        <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none" class="relative block w-full h-[40px] md:h-[50px] text-primary" fill="currentColor">
          <path d="M985.66,92.83C906.67,72,823.78,31,743.84,14.19c-82.26-17.34-168.06-16.33-250.45.39-57.84,11.73-114,31.07-172,41.86A600.21,600.21,0,0,1,0,27.35V120H1200V95.8C1132.19,118.92,1055.71,111.31,985.66,92.83Z"></path>
        </svg>
      </div>

      <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-6 md:gap-8 text-center md:text-left">
        
        <div class="md:col-span-2 pr-0 md:pr-12">
          <h3 class="text-xl font-bold mb-3">Baby Bella Italian Foods</h3>
          <p class="opacity-80 leading-relaxed text-sm">Nourishing your little ones with authentic Italian organic ingredients.</p>
        </div>
        
        <div class="md:col-span-1">
          <h4 class="font-bold mb-3 text-base">Quick Links</h4>
          <ul class="space-y-2 opacity-80 text-sm">
            <li><a href="/BellaItalianFoods/shop" class="hover:opacity-100 transition-opacity">Shop Collection</a></li>
            <li><a href="/BellaItalianFoods/contact" class="hover:opacity-100 transition-opacity">Contact Support</a></li>
          </ul>
        </div>
        
        <div class="md:col-span-1">
          <h4 class="font-bold mb-3 text-base">Follow Us</h4>
          <div class="flex justify-center md:justify-start space-x-4">
            <a href="https://www.facebook.com/people/Baby-Bella-Italian-food/61587348849143/" target="_blank" rel="noopener noreferrer" class="text-2xl opacity-80 hover:opacity-100 hover:text-white transition-all transform hover:scale-110" aria-label="Facebook">
              <i class="fa-brands fa-facebook"></i>
            </a>
            <a href="https://www.tiktok.com/@babybellaitalianfood?is_from_webapp=1&sender_device=pc" target="_blank" rel="noopener noreferrer" class="text-2xl opacity-80 hover:opacity-100 hover:text-white transition-all transform hover:scale-110" aria-label="TikTok">
              <i class="fa-brands fa-tiktok"></i>
            </a>
            <a href="https://www.whatsapp.com/channel/0029VbCEbOq0gcfISCbdYW2m" target="_blank" rel="noopener noreferrer" class="text-2xl opacity-80 hover:opacity-100 hover:text-white transition-all transform hover:scale-110" aria-label="WhatsApp">
              <i class="fa-brands fa-whatsapp"></i>
            </a>
          </div>
        </div>
        
      </div>
      
      <div class="max-w-6xl mx-auto px-6 mt-8 pt-4 border-t border-white/20 text-center opacity-60 text-xs md:text-sm">
        &copy; 2026 Baby Bella Italian Foods. All rights reserved.
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');

      btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
        menu.classList.toggle('flex');
      });
    </script>
  </body>
</html>
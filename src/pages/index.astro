---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. Fetch products from the CMS collection
const allProducts = await getCollection('products');

// 2. Sort by newest and grab the top 4 to display as favorites
const topFavorites = allProducts
  .sort((a, b) => b.data.publish_date.valueOf() - a.data.publish_date.valueOf())
  .slice(0, 4);
---

<Layout title="Home">
  
  <!-- SECTION 1: HERO -->
  <section id="home" class="max-w-6xl mx-auto px-4 mt-6 mb-12 md:h-[calc(100vh-9rem)] md:min-h-[450px] md:max-h-[600px]">
    <div class="bg-teal-800 rounded-[3rem] shadow-2xl flex flex-col md:flex-row items-stretch overflow-hidden h-full">
      
      <!-- Text Content (Left Side) -->
      <div class="w-full md:w-1/2 p-8 md:p-10 lg:p-12 flex flex-col items-start justify-center text-left">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4 leading-tight text-white">
          Pure Italian Love <br/>
          <span class="text-[#CADCAE]">for Sri Lankan Babies.</span>
        </h1>
        
        <p class="text-sm md:text-base mb-8 text-gray-200 max-w-md leading-relaxed">
          Organic, wholesome baby food inspired by the heart of Italy, now available in Sri Lanka. Give your child the perfect healthy start.
        </p>
        
        <a 
          href="/BellaItalianFoods/shop" 
          class="bg-[#CADCAE] text-gray-900 px-6 py-3 rounded-md font-bold text-sm tracking-widest uppercase hover:bg-white transition-all shadow-lg inline-block">
          Shop Products
        </a>
      </div>
      
      <!-- Image Container (Right Side) -->
      <div class="w-full md:w-1/2 p-4 md:p-6 md:pl-0 flex">
        <img 
          src="/BellaItalianFoods/images/hero-bg.jpg" 
          alt="Wholesome Italian Baby Food" 
          class="w-full h-full min-h-[300px] md:min-h-0 object-cover rounded-[2rem] shadow-inner" 
        />
      </div>
      
    </div>
  </section>

  <!-- SECTION 2: ABOUT US -->
  <section id="about" class="bg-red-50 w-full py-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        
        <!-- Image Container -->
        <div class="w-full h-80 md:h-96 rounded-[3rem] shadow-sm overflow-hidden">
          <img 
            src="/BellaItalianFoods/images/about.jpg" 
            alt="About Us - img" 
            class="w-full h-full object-cover" 
          />
        </div>
        
        <!-- Text Content -->
        <div>
          <h2 class="text-4xl font-bold text-secondary mb-6">From Italy to Sri Lanka</h2>
          <p class="text-gray-600 leading-relaxed mb-6 text-lg">
            We believe that a baby's first foods should be as vibrant and full of life as they are. Sourced directly from sustainable farms in Italy and brought right here to Sri Lanka, our purees and pastas introduce your baby to real, premium food without any artificial additives.
          </p>
        </div>
        
      </div>
    </div>
  </section>

  <!-- SECTION 3: TOP FAVORITES -->
  <section class="bg-white pt-20 pb-32">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-secondary mb-4">Top Favorites</h2>
        <p class="text-gray-500">Explore the wholesome baby foods local parents are loving the most this week.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- 3. Loop through the fetched topFavorites -->
        {topFavorites.map((product) => (
          <div class="bg-background rounded-3xl p-6 shadow-sm hover:shadow-xl transition-shadow text-center flex flex-col h-full">
            
            <!-- Updated Image container -->
            <div class="h-40 bg-gray-50 rounded-2xl mb-6 flex items-center justify-center overflow-hidden relative text-gray-400">
              {product.data.image ? (
                <img src={product.data.image} alt={product.data.title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
              ) : (
                <span class="text-gray-300 font-bold">[No Image]</span>
              )}
            </div>
            
            <!-- Updated Title -->
            <h3 class="text-xl font-bold text-secondary mb-2 leading-tight">{product.data.title}</h3>
            
            <!-- Updated Price and Button -->
            <div class="mt-auto pt-4 flex justify-between items-center">
              <span class="text-2xl font-bold text-primary">Rs. {product.data.price.toFixed(2)}</span>
              <a href="/BellaItalianFoods/shop" class="bg-secondary text-white px-5 py-2 rounded-full hover:bg-opacity-90 font-bold text-sm tracking-wide">Shop Now</a>
            </div>
            
          </div>
        ))}
      </div>
    </div>
  </section>
  

</Layout>
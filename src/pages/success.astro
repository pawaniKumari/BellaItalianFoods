---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Message Sent - Baby Bella Italian Foods">
  <div class="max-w-6xl mx-auto px-4 py-16 md:py-24 min-h-[60vh] flex items-center justify-center">
    
    <div class="bg-white rounded-3xl p-8 md:p-12 border border-gray-100 shadow-sm text-center max-w-lg mx-auto transition-all hover:shadow-xl">
      
      <!-- Success Icon -->
      <div class="mb-6 flex justify-center">
        <div class="h-20 w-20 bg-green-100 rounded-full flex items-center justify-center">
          <i class="fa-solid fa-check text-4xl text-green-500"></i>
        </div>
      </div>

      <!-- Text Content -->
      <h1 class="text-3xl md:text-4xl font-bold text-secondary mb-4 leading-tight">
        Message Sent!
      </h1>
      <p class="text-gray-500 mb-8 leading-relaxed">
        Thank you for reaching out to Baby Bella Italian Foods. We have received your inquiry and will get back to you as soon as possible.
      </p>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mt-6">
        <a href="/BellaItalianFoods/" class="inline-block whitespace-nowrap text-center bg-primary text-white font-bold py-3 px-8 rounded-full hover:bg-opacity-90 hover:shadow-lg hover:-translate-y-0.5 transition-all uppercase tracking-wider text-sm shadow-sm">
          Back to Home
        </a>
        <a href="/BellaItalianFoods/shop" class="inline-block whitespace-nowrap text-center bg-white text-gray-600 border-2 border-gray-200 font-bold py-3 px-8 rounded-full hover:border-primary hover:text-primary hover:-translate-y-0.5 transition-all uppercase tracking-wider text-sm">
          Keep Shopping
        </a>
      </div>

    </div>
    
  </div>
</Layout>
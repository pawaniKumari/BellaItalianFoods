---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us - Baby Bella Italian Foods">
  
  <!-- Top Banner Area -->
  <!-- Adjusted height and top padding to accommodate the higher overlap -->
  <div class="w-full h-[350px] md:h-[400px] bg-secondary relative overflow-hidden flex items-start justify-center pt-12 text-gray-400">
    <img src="/BellaItalianFoods/images/contact.png" alt="Contact Us Background" class="absolute inset-0 w-full h-full object-cover opacity-80" />
  </div>

  <!-- Main Content Wrapper -->
  <!-- Increased negative top margin to md:-mt-72 and lg:-mt-80 to push the form much higher -->
  <div class="max-w-6xl mx-auto px-4 pb-16 relative z-10 -mt-48 md:-mt-72 lg:-mt-80">
    
    <!-- Floating Contact Card -->
    <!-- Slightly reduced padding/gaps to make the card more compact vertically -->
    <div class="flex flex-col md:flex-row gap-8 lg:gap-12 bg-white p-6 md:p-10 lg:p-12 rounded-3xl shadow-xl border border-gray-50">
      
      <!-- Left Column: Details & Socials -->
      <div class="w-full md:w-5/12 flex flex-col">
        <h1 class="text-4xl font-bold text-primary mb-3">Get in Touch</h1>
        <p class="text-gray-500 text-sm mb-6 leading-relaxed">
          Interested in pre-ordering our wholesome Italian baby foods or have questions about our ingredients? We'd love to hear from you!
        </p>
        
        <!-- Contact Info -->
        <div class="space-y-5 text-gray-500 text-sm mb-8">
          <div>
            <p>+94 74 330 6203</p>
          </div>
          <div>
            <a href="mailto:ukderandi@gmail.com" class="text-primary font-medium hover:underline transition-all">ukderandi@gmail.com</a>
          </div>
        </div>

        <!-- Social Links -->
        <div>
          <h3 class="font-bold text-gray-800 uppercase tracking-widest text-xs mb-4">Connect With Us</h3>
          <div class="flex flex-row gap-5">
            <a href="https://www.facebook.com/people/Baby-Bella-Italian-food/61587348849143/#" target="_blank" class="w-14 h-14 bg-gray-50 text-primary border border-gray-100 rounded-full flex items-center justify-center text-xl shadow-sm hover:bg-primary hover:text-white hover:-translate-y-1 transition-all duration-300" aria-label="Facebook">
              <i class="fa-brands fa-facebook-f"></i>
            </a>
            <a href="https://www.tiktok.com/@babybellaitalianfood?is_from_webapp=1&sender_device=pc" target="_blank" class="w-14 h-14 bg-gray-50 text-primary border border-gray-100 rounded-full flex items-center justify-center text-xl shadow-sm hover:bg-primary hover:text-white hover:-translate-y-1 transition-all duration-300" aria-label="TikTok">
              <i class="fa-brands fa-tiktok"></i>
            </a>
            <a href="https://www.whatsapp.com/channel/0029VbCEbOq0gcfISCbdYW2m" target="_blank" class="w-14 h-14 bg-gray-50 text-primary border border-gray-100 rounded-full flex items-center justify-center text-xl shadow-sm hover:bg-primary hover:text-white hover:-translate-y-1 transition-all duration-300" aria-label="WhatsApp">
              <i class="fa-brands fa-whatsapp"></i>
            </a>
          </div>
        </div>
      </div>
      
      <!-- Right Column: Form -->
      <div class="w-full md:w-7/12">
  <form action="https://api.web3forms.com/submit" method="POST" class="flex flex-col gap-5 bg-gray-50/50 p-6 md:p-8 rounded-2xl border border-gray-100">
    
    <!-- REQUIRED: Web3Forms Access Key -->
    <input type="hidden" name="access_key" value="a63420f1-d2ba-4161-aa48-b1efd65b1401">

    <!-- <input type="hidden" name="redirect" value="http://localhost:4321/BellaItalianFoods/success"> -->
    <!-- Change this line in your contact.astro form -->
<input type="hidden" name="redirect" value="https://pawanikumari.github.io/BellaItalianFoods/success">
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      
      <!-- Row 1: Full Name & Phone -->
      <div class="flex flex-col gap-1.5">
        <label class="text-gray-700 font-bold text-xs uppercase tracking-wider">Full Name <span class="text-red-500">*</span></label>
        <!-- Added name="name" -->
        <input type="text" name="name" placeholder="Your Full Name" class="w-full border border-gray-200 bg-white p-3 rounded-lg outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors text-sm" required />
      </div>
      <div class="flex flex-col gap-1.5">
        <label class="text-gray-700 font-bold text-xs uppercase tracking-wider">Phone Number</label>
        <!-- Added name="phone" -->
        <input type="tel" name="phone" placeholder="Phone" class="w-full border border-gray-200 bg-white p-3 rounded-lg outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors text-sm" />
      </div>
      
      <!-- Row 2: Email & Subject -->
      <div class="flex flex-col gap-1.5">
        <label class="text-gray-700 font-bold text-xs uppercase tracking-wider">Email Address <span class="text-red-500">*</span></label>
        <!-- Added name="email" -->
        <input type="email" name="email" placeholder="Email Address" class="w-full border border-gray-200 bg-white p-3 rounded-lg outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors text-sm" required />
      </div>
      <div class="flex flex-col gap-1.5">
        <label class="text-gray-700 font-bold text-xs uppercase tracking-wider">Inquiry Type <span class="text-red-500">*</span></label>
        <!-- Added name="inquiry_type" -->
        <select name="inquiry_type" class="w-full border border-gray-200 bg-white p-3 rounded-lg outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors text-sm cursor-pointer" required>
          <option value="" disabled selected>Select a topic...</option>
          <option value="preorder">Pre-Order Request</option>
          <option value="product_question">Product Ingredients / Age Guide</option>
          <option value="other">Other Inquiry</option>
        </select>
      </div>
    </div>

    <!-- Message Area -->
    <div class="flex flex-col gap-1.5">
      <label class="text-gray-700 font-bold text-xs uppercase tracking-wider">Your Message <span class="text-red-500">*</span></label>
      <!-- Added name="message" -->
      <textarea name="message" rows="4" placeholder="Let us know which products you're looking to pre-order..." class="w-full border border-gray-200 bg-white p-3 rounded-lg outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors resize-y text-sm" required></textarea>
    </div>
    
    <!-- Submit Button -->
    <div class="mt-2">
      <button type="submit" class="w-full md:w-auto bg-primary text-white font-bold py-3 px-10 rounded-full hover:bg-opacity-90 hover:shadow-lg hover:-translate-y-0.5 transition-all uppercase tracking-wider text-sm shadow-sm">
        Send Message
      </button>
    </div>
  </form>
</div>

    </div>
  </div>
</Layout>